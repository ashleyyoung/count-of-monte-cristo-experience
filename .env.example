# Copy to .env.local for local development.
# Production and preview values live in the Vercel project (GitHub-connected deploys).
# Optional: `vercel env pull .env.local` after `vercel link` to sync from Vercel.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Supabase (auth + data)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for admin/service operations in API routes.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage via S3-compatible API)
# Used from Vercel serverless functions / API routes, same pattern as stock-tracker.
# Create R2 API tokens in the Cloudflare dashboard (R2 → Manage R2 API Tokens).
# -----------------------------------------------------------------------------

CLOUDFLARE_ACCOUNT_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=count-of-monte-cristo-experience

# Optional public base URL when serving objects from R2.
# R2_PUBLIC_URL=https://pub-<id>.r2.dev
