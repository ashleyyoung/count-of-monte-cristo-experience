# Copy to .env.local for local development.
# Production and preview values live in the Vercel project (GitHub-connected deploys).
# Optional: `vercel env pull .env.local` after `vercel link` to sync from Vercel.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Supabase (auth + data)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for admin/service operations in API routes.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage via S3-compatible API)
# Used from Vercel serverless functions / API routes, same pattern as stock-tracker.
# Create R2 API tokens in the Cloudflare dashboard (R2 → Manage R2 API Tokens).
# -----------------------------------------------------------------------------

CLOUDFLARE_ACCOUNT_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=count-of-monte-cristo-experience

# Optional public base URL when serving objects from R2.
# R2_PUBLIC_URL=https://pub-<id>.r2.dev

# -----------------------------------------------------------------------------
# Translation (Sprint 9 pipeline + local runner)
# Model is fully configurable; nothing is hardcoded. See
# README_translation_architecture.md.
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
TRANSLATION_PROVIDER=anthropic
# Default while Claude Fable 5 is blocked from public use; switch to
# claude-fable-5 when it returns.
TRANSLATION_MODEL=claude-sonnet-4-6
# Optional; vision OCR model. Falls back to TRANSLATION_MODEL when unset.
TRANSLATION_VISION_MODEL=claude-sonnet-4-6
# Optional; max output tokens for the whole-issue translate+segment call.
# Raise if a long issue truncates (the run fails loudly on truncation). Default 32000.
# TRANSLATION_MAX_OUTPUT_TOKENS=32000
# Optional; max output tokens for a single-section translation / vision transcription. Default 16000.
# TRANSLATION_SINGLE_MAX_OUTPUT_TOKENS=16000
# Message Batches API for translate-day / translate-all (50% token discount). Set to 0 for streaming (--sync).
# TRANSLATION_USE_BATCH=1
# TRANSLATION_BATCH_POLL_MS=5000

# Enables the Translate admin button, which spawns the local
# CLI runner (scripts/translate/translate-day.ts) on YOUR machine. Always on in
# development; set to 1 to enable in other local/self-hosted contexts. Leave
# unset on a plain production deploy (no local process there to run the work).
# LOCAL_TRANSLATION_RUNNER=1

# -----------------------------------------------------------------------------
# Gallica (BnF) HTTP client
# BnF asks automated clients to identify themselves with a contact. Cloudflare
# bot protection can return 403; an identifying User-Agent and Referer help.
# -----------------------------------------------------------------------------

# Contact appended to the default User-Agent (email or project URL). Recommended.
# GALLICA_CONTACT=you@example.com
# Full override of the User-Agent string (takes precedence over GALLICA_CONTACT).
# GALLICA_USER_AGENT=monte-cristo-archive/1.0 (+https://example.com)
# Max fetch attempts per Gallica request (default 6).
# GALLICA_MAX_ATTEMPTS=6
# Cap on any single retry backoff wait in ms (default 300000 = 5 min).
# GALLICA_MAX_BACKOFF_MS=300000
